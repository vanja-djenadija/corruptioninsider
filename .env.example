# ===== DATABASE =====
POSTGRES_DB=corruptioninsider
POSTGRES_USER=corruption_user
POSTGRES_PASSWORD=insertpassword
DATABASE_URL=postgresql://corruption_user:insertpassword@postgres:5432/corruptioninsider

# ===== SECURITY =====
JWT_SECRET=insertsecret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== FRONTEND =====
NEXT_PUBLIC_API_BASE_URL=https://corruptioninsider.com/api

# ===== CORS =====
CORS_ORIGINS=https://corruptioninsider.com

# ===== DATA SOURCES =====
OPENSANCTIONS_API_KEY=...

# ===== ENV =====
ENVIRONMENT=production